{
  "name": "@vitadeck/sdk",
  "version": "0.5.0",
  "keywords": [
    "cli",
    "deck-app",
    "playstation-vita",
    "ps-vita",
    "react",
    "vita",
    "vitadeck"
  ],
  "homepage": "https://github.com/matemolnar8/vitadeck/tree/main/js/packages/sdk",
  "bugs": {
    "url": "https://github.com/matemolnar8/vitadeck/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/matemolnar8/vitadeck.git",
    "directory": "js/packages/sdk"
  },
  "bin": {
    "vitadeck": "./dist/cli.mjs"
  },
  "files": [
    "dist",
    "tsconfig.deck-app.json"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./internal": {
      "types": "./dist/internal.d.ts",
      "import": "./dist/internal.js",
      "default": "./dist/internal.js"
    },
    "./tsconfig": "./tsconfig.deck-app.json",
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js",
      "default": "./dist/types.js"
    },
    "./vitadeck-host-types": {
      "types": "./dist/vitadeck-host-types.d.ts",
      "import": "./dist/vitadeck-host-types.js",
      "default": "./dist/vitadeck-host-types.js"
    },
    "./deck-app-env": "./dist/deck-app-globals.d.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build:lib": "tsc -p tsconfig.build.json",
    "build:cli": "rolldown -c rolldown.cli.config.mjs && tsx cli/copy-templates.ts",
    "build": "tsx cli/clean-dist.ts && pnpm run build:lib && pnpm run build:cli",
    "prepublishOnly": "pnpm run build",
    "tsc": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@babel/preset-react": "catalog:",
    "@babel/preset-typescript": "catalog:",
    "@rollup/plugin-babel": "catalog:",
    "babel-plugin-react-compiler": "catalog:",
    "fflate": "catalog:",
    "rolldown": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "react": "catalog:",
    "tsx": "catalog:"
  },
  "peerDependencies": {
    "react": "catalog:"
  }
}
