{
  "name": "vitadeck-workspace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "pnpm --filter @vitadeck/sdk run build",
    "build": "pnpm --filter @vitadeck/sdk build && pnpm --filter \"./examples/*\" build && pnpm --filter @vitadeck/runtime build",
    "build:prod": "NODE_ENV=production pnpm build",
    "tsc": "pnpm --filter @vitadeck/sdk tsc && pnpm --filter @vitadeck/runtime tsc && pnpm --filter \"./examples/*\" tsc",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check"
  },
  "devDependencies": {
    "@babel/preset-react": "catalog:",
    "@babel/preset-typescript": "catalog:",
    "@rollup/plugin-babel": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-reconciler": "catalog:",
    "typescript": "catalog:",
    "babel-plugin-react-compiler": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "react": "catalog:",
    "react-compiler-runtime": "catalog:",
    "react-reconciler": "catalog:",
    "rolldown": "catalog:",
    "tslib": "catalog:",
    "tsx": "catalog:"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.28.2+sha512.41872f037ad22f7348e3b1debbaf7e867cfd448f2726d9cf74c08f19507c31d2c8e7a11525b983febc2df640b5438dee6023ebb1f84ed43cc2d654d2bc326264"
}
