{
  "compilerOptions": {
    "module": "esnext",
    "target": "es2015",
    "types": [],
    "lib": ["es5", "es2015"],
    "noEmit": true,
    "noUncheckedIndexedAccess": true,
    "strict": true,
    "jsx": "react",
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "moduleResolution": "bundler",
    "paths": {
      "@vitadeck/active-deck-app": ["./src/generated/active-deck-app.ts"],
      "@vitadeck/runtime": ["./src/runtime/index.tsx"],
      "react": ["./node_modules/@types/react/index.d.ts"],
      "react/*": ["./node_modules/@types/react/*"]
    },
    "skipLibCheck": true,
    "esModuleInterop": true
  },
  "include": ["src", "deck-apps"]
}
